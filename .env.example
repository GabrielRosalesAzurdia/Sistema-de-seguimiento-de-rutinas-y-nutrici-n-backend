# Django
SECRET_KEY=changeme-generate-a-real-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos (PostgreSQL - Neon en producción, local/Docker en desarrollo)
DB_NAME=club_fitness
DB_USER=club_fitness
DB_PASSWORD=club_fitness
DB_HOST=localhost
DB_PORT=5432
# Neon exige SSL: poner DB_SSLMODE=require en Render. Local/Docker no
# lo necesitan, se deja "prefer" por default (no rompe nada).
DB_SSLMODE=prefer

# CORS (dominios permitidos para el admin panel / app)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# CSRF (necesario para los formularios POST del panel admin; en Render
# usar el dominio real con https://, ej. https://tu-app.onrender.com)
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Endurecimiento HTTPS (dejar en False en local; poner True en Render)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
